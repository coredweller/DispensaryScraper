# Required: Comma-separated brand names to filter for
BRANDS=Viola,710 Labs

# Required: Gmail credentials for SMTP sending
GMAIL_USER=your.email@gmail.com
GMAIL_PASS=your16charapppassword

# Required: Email address to receive the report
RECIPIENT_EMAIL=recipient@example.com

# Optional: Full URL of the dispensary menu page (defaults to Krystal Leaves)
TARGET_URL=https://www.krystaleaves.com/menu

# Optional: Set to false to watch the browser during development (default: true)
HEADLESS=true

# Optional: Path where failure screenshots are saved (default: screenshots/debug.png)
DEBUG_SCREENSHOT_PATH=screenshots/debug.png
