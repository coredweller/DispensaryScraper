{
  "name": "dispensary-scraper",
  "version": "1.0.0",
  "description": "Scrapes Krystal Leaves dispensary menu and emails Viola & 710 Labs flower strain results",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "typecheck": "npx tsc --noEmit",
    "test": "npx vitest run tests/unit",
    "test:integration": "npx vitest run tests/integration"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.9.13",
    "puppeteer": "^23.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
